---
import { Button, Spoiler } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' }
]
---

<PageLayout title='About' {headings} comment>
  <p>Developer / Music Producer / DJ</p>
  <p>XJTU' 23 Automation</p>
  <ul>
  <li>非典型 INFP，四个字母全在 50%～60%</li>
  <li>多风格作编曲混音母带音乐一体机，XJTU 原创音乐社社长，擅长电子 / 流行 / 管弦编曲，专精电子，作品发过 SoulNotes / Phono / Chillme / Citysounds 等国内各大厂牌，给游戏供曲，可以找我帮忙写歌😎</li>
  <li>整点机器人，某机器人社团视觉组组长，机器人视觉和导航，球球了再拿一次国一吧😭</li>
  <li>瞎搞人工智能，纯新手，数据挖掘，推荐系统，大模型啥的完全搞不懂，想学会又什么都学不会😵‍💫</li>
  <li>乱造视觉设计，blender 什么效果什么操作往上怼，造出什么东西纯靠运气🤡</li>
  </ul>
  <p>
    <Spoiler>この世界は騒がし過ぎるから，聞かないで，見ないで，構わないで，そして前に進め</Spoiler>
  </p>
  <div class='not-prose flex flex-wrap gap-3'>
    <Button
      title='Sponsor Me'
      class='glass-button w-fit'
      href='/projects#sponsorship'
      variant='ahead'
    />
    <Button
      title='My CV'
      class='glass-button w-fit'
      href='/cv_zh.pdf'
      target='_blank'
      variant='ahead'
    />
  </div>

  {/* general-talk */}
  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li>Coding</li>
    <li>Large Language Models</li>
    <li>Data Mining / Recommendation Systems</li>
    <li>Robotics / Computer Vision / Navigation</li>
    <li>Music Production / Sound Design</li>
  </ul>

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <ToolSection
    class='mb-5'
    title='Tools'
    tools={[
      {
        name: 'VS Code',
        description: 'IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Cursor',
        description: 'IDE',
        href: 'https://www.cursor.com/',
        icon: import('@/assets/tools/cursor.svg?raw')
      },
      {
        name: 'Fl Studio',
        description: 'Music Production',
        href: 'https://www.flstudio.com/',
        icon: import('@/assets/tools/flstudio.svg?raw')
      },
      {
        name: 'Ableton Live',
        description: 'Music Production',
        href: 'https://www.ableton.com/en/',
        icon: import('@/assets/tools/abletonlive.svg?raw')
      },
      {
        name: 'Bitwig Studio',
        description: 'Music Production',
        href: 'https://www.bitwig.com/',
        icon: import('@/assets/tools/bitwig.svg?raw')
      },
      {
        name: 'Max',
        description: 'Interactive Music Design',
        href: 'https://cycling74.com/products/max',
        icon: import('@/assets/tools/max.svg?raw')
      },
      {
        name: 'Adobe Illustrator',
        description: 'Design',
        href: 'https://www.adobe.com/products/illustrator.html',
        icon: import('@/assets/tools/illustrator.svg?raw')
      },
      {
        name: 'Blender',
        description: '3D Modeling',
        href: 'https://www.blender.org/',
        icon: import('@/assets/tools/blender.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Environment'
    tools={[
      {
        name: 'Ubuntu 22.04 LTS',
        description: 'Linux Distribution',
        href: 'https://ubuntu.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      },
      {
        name: 'Windows 11',
        description: 'Framework Laptop 16',
        href: 'https://news.microsoft.com/windows11-general-availability/',
        icon: import('@/assets/tools/windows11.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <p></p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/ZeroHour-Z',
        text: 'followers',
        api: 'github/ZeroHour-Z'
      },
      {
        platform: 'Netease Music',
        icon: 'netease',
        link: 'https://music.163.com/#/artist?id=33400424',
        text: 'followers',
        api: 'neteasemusic/1761035398'
      },
      {
        platform: 'Bilibili',
        icon: 'bilibili',
        link: 'https://space.bilibili.com/499513500',
        text: 'followers',
        api: 'bilibili/499513500'
      },
      {
        platform: 'X',
        icon: 'x',
        link: 'https://x.com/ZeroHour0S',
        text: 'followers',
        // api: 'x/ZeroHour0S'
        count: 22
      }
    ]}
  />

